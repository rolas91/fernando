PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=fernando

# JWT
# En producción usa un secreto largo y aleatorio (>= 32 chars) y no lo commitees.
JWT_SECRET=cambia-esto-por-un-secreto-largo-en-produccion
JWT_EXPIRES_IN=7d

# Swagger
# Por defecto se habilita fuera de producción. Podés forzarlo con true/false.
SWAGGER_ENABLED=true

# Rol por defecto al registrarse
DEFAULT_ROLE_KEY=user

# Opcional: seed admin (npm run seed:iam)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Seed DR (npm run seed:dr)
SEED_ADMIN_EMAIL=derek@drtrafficcontrol.com
SEED_ADMIN_PASSWORD=admin123
SEED_MANAGER_EMAIL=sarah@drtrafficcontrol.com
SEED_MANAGER_PASSWORD=manager123
SEED_SCHEDULER_EMAIL=mike@drtrafficcontrol.com
SEED_SCHEDULER_PASSWORD=scheduler123
SEED_VIEWER_EMAIL=jenny@drtrafficcontrol.com
SEED_VIEWER_PASSWORD=viewer123
# true para regenerar hash de password en usuarios existentes
SEED_USERS_RESET_PASSWORDS=false

# Realtime / CORS
CORS_ORIGIN=http://localhost:8080

# Servir frontend estático desde el backend (SPA)
# En producción suele ser true cuando despliegas monolítico
SERVE_FRONTEND=false
# Ruta al build del frontend (si omites, usa ../frontend/dist)
FRONTEND_DIST_PATH=

# Seguridad estilo Firebase
# true: no bloquea desarrollo local sin token
# false: exige JWT y roles estrictos en todas las rutas protegidas
AUTH_DEV_BYPASS=true

# Twilio (placeholders)
TWILIO_ACCOUNT_SID=placeholder-twilio-sid
TWILIO_AUTH_TOKEN=placeholder-twilio-token
TWILIO_FROM_NUMBER=+10000000000

# SMTP (placeholders)
SMTP_HOST=placeholder.smtp.host
SMTP_PORT=587
SMTP_USER=placeholder@example.com
SMTP_PASS=placeholder-password
SMTP_FROM=no-reply@example.com

# Geocoding (placeholders)
# Opciones: placeholder | mapbox | opencage
GEOCODING_PROVIDER=placeholder
GEOCODING_API_KEY=placeholder-geocoding-key
