PORT=3000
NODE_ENV=production

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=fernando

# Use a secure random secret in production
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=7d

SWAGGER_ENABLED=false
DEFAULT_ROLE_KEY=user

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# Set your real frontend domain(s), comma separated
CORS_ORIGIN=https://your-frontend-domain.com
SERVE_FRONTEND=true
FRONTEND_DIST_PATH=/app/public

# Production strict mode: enforce JWT and role checks
AUTH_DEV_BYPASS=false

TWILIO_ACCOUNT_SID=placeholder-twilio-sid
TWILIO_AUTH_TOKEN=placeholder-twilio-token
TWILIO_FROM_NUMBER=+10000000000

SMTP_HOST=placeholder.smtp.host
SMTP_PORT=587
SMTP_USER=placeholder@example.com
SMTP_PASS=placeholder-password
SMTP_FROM=no-reply@example.com

GEOCODING_PROVIDER=placeholder
GEOCODING_API_KEY=placeholder-geocoding-key
